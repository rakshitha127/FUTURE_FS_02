{
  "name": "mini-crm-lead-manager",
  "version": "1.0.0",
  "description": "Client Lead Management System built with React, Express, and MongoDB.",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "start": "node server/index.js",
    "client": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "seed": "node server/seedAdmin.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "bcryptjs": "^2.4.3",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.468.0",
    "mongodb": "^7.3.0",
    "mongoose": "^8.9.5",
    "nodemon": "^3.1.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^8.0.16"
  }
}
